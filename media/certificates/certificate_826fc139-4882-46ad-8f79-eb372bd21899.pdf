<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>OpenLaw Certificate</title>
    <style>
        @page {
            size: A4;
            margin: 2cm;
        }
        body {
            font-family: 'Times New Roman', serif;
            line-height: 1.6;
            color: #333;
        }
        .header {
            text-align: center;
            border-bottom: 3px solid #2c3e50;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        .logo {
            font-size: 28px;
            font-weight: bold;
            color: #2c3e50;
            margin-bottom: 10px;
        }
        .certificate-type {
            font-size: 24px;
            font-weight: bold;
            color: #34495e;
            margin: 20px 0;
            text-align: center;
        }
        .certificate-id {
            text-align: center;
            font-size: 14px;
            color: #7f8c8d;
            margin-bottom: 30px;
        }
        .section {
            margin: 20px 0;
        }
        .section-title {
            font-weight: bold;
            font-size: 16px;
            color: #2c3e50;
            margin-bottom: 10px;
        }
        .land-details {
            background-color: #f8f9fa;
            padding: 15px;
            border-left: 4px solid #3498db;
            margin: 20px 0;
        }
        .case-item {
            background-color: #fff9e6;
            padding: 10px;
            margin: 10px 0;
            border-left: 4px solid #f39c12;
        }
        .footer {
            margin-top: 50px;
            text-align: center;
            border-top: 2px solid #2c3e50;
            padding-top: 20px;
        }
        .stamp {
            border: 2px solid #2c3e50;
            border-radius: 50%;
            width: 100px;
            height: 100px;
            display: inline-block;
            text-align: center;
            line-height: 100px;
            font-weight: bold;
            color: #2c3e50;
            margin: 20px auto;
        }
        .generated-date {
            font-size: 14px;
            color: #7f8c8d;
            text-align: center;
        }
        
        .status-flag {
            padding: 15px;
            margin: 10px 0;
            border-radius: 5px;
            border-left: 4px solid;
        }
        
        .status-flag.ongoing {
            background-color: #f8d7da;
            border-color: #dc3545;
            color: #721c24;
        }
        
        .status-flag.resolved {
            background-color: #d4edda;
            border-color: #28a745;
            color: #155724;
        }
        
        .status-flag.unknown {
            background-color: #fff3cd;
            border-color: #ffc107;
            color: #856404;
        }
        
        .case-status {
            font-weight: bold;
            margin-bottom: 8px;
            padding: 5px;
            border-radius: 3px;
        }
        
        .ongoing-case .case-status {
            background-color: #f8d7da;
            color: #721c24;
        }
        
        .resolved-case .case-status {
            background-color: #d4edda;
            color: #155724;
        }
        
        .unknown-case .case-status {
            background-color: #fff3cd;
            color: #856404;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">OpenLaw Kenya</div>
        <div>Land Due Diligence & Litigation Intelligence System</div>
    </div>

    <div class="certificate-type">
        
            CASE-LINKED CERTIFICATE
        
    </div>

    <div class="certificate-id">
        Certificate ID: 826fc139-4882-46ad-8f79-eb372bd21899
    </div>

    <div class="section">
        <div class="section-title">Land Details</div>
        <div class="land-details">
            <strong>Title Number:</strong> Chembe/Kibabamshe/393<br>
            
            <strong>Plot Number:</strong> Chembe/Kibabamshe/393<br>
            
            
            
        </div>
    </div>

    
    <div class="section">
        <div class="section-title">Litigation Status Summary</div>
        
        
        <div class="status-flag ongoing">
            <strong>⚠️ ACTIVE LITIGATION DETECTED</strong><br>
            1 ongoing case(s) requiring attention
        </div>
        
        
        
        
        
    </div>

    
    <div class="section">
        <div class="section-title">Ongoing Litigation (Rulings)</div>
        
        <div class="case-item ongoing-case">
            <div class="case-status">🔴 ACTIVE - RULING</div>
            <strong>Case Number:</strong> KEELC/2019/80<br>
            <strong>Case Name:</strong> Soft White Beach Limited v Joseph Kashuru Mumbo, Masumbuko Yerry Kombe, Attorney General, Chief Land Registrar &amp; District Land Registrar Kilifi; Joseph Nicholas Murage (As Administrator of the Estate of Benard Chiori Murage (Proposed Interested Party) (Environment &amp; Land Case 11 &amp; 30 of 2011) [2019] KEELC 80 (KLR) (5 December 2019) (Ruling)<br>
            <strong>Court:</strong> Malindi<br>
            <strong>Year:</strong> 2019<br>
            <strong>Status:</strong> Ruling<br>
            <strong>Parties:</strong> Plaintiff: Soft White Beach Limited
Defendant: Joseph Kashuru Mumbo, Masumbuko Yerry Kombe, Attorney General, Chief Land Registrar &amp; District Land Registrar Kilifi; Joseph Nicholas Murage (As Administrator of the Estate of Benard Chiori Murage (Proposed Interested Party) (Environment &amp; Land Case 11 &amp; 30 of 2011)
        </div>
        
    </div>
    

    

    
    </div>
    

    <div class="footer">
        <div class="stamp">OFFICIAL</div>
        <div>This certificate is electronically generated by OpenLaw Kenya</div>
        <div class="generated-date">Generated on: 25 February 2026</div>
    </div>
</body>
</html>
