<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>OpenLaw Certificate</title>
    <style>
        @page {
            size: A4;
            margin: 2cm;
        }
        body {
            font-family: 'Times New Roman', serif;
            line-height: 1.6;
            color: #333;
        }
        .header {
            text-align: center;
            border-bottom: 3px solid #2c3e50;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        .logo {
            font-size: 28px;
            font-weight: bold;
            color: #2c3e50;
            margin-bottom: 10px;
        }
        .certificate-type {
            font-size: 24px;
            font-weight: bold;
            color: #34495e;
            margin: 20px 0;
            text-align: center;
        }
        .certificate-id {
            text-align: center;
            font-size: 14px;
            color: #7f8c8d;
            margin-bottom: 30px;
        }
        .section {
            margin: 20px 0;
        }
        .section-title {
            font-weight: bold;
            font-size: 16px;
            color: #2c3e50;
            margin-bottom: 10px;
        }
        .land-details {
            background-color: #f8f9fa;
            padding: 15px;
            border-left: 4px solid #3498db;
            margin: 20px 0;
        }
        .case-item {
            background-color: #fff9e6;
            padding: 10px;
            margin: 10px 0;
            border-left: 4px solid #f39c12;
        }
        .footer {
            margin-top: 50px;
            text-align: center;
            border-top: 2px solid #2c3e50;
            padding-top: 20px;
        }
        .stamp {
            border: 2px solid #2c3e50;
            border-radius: 50%;
            width: 100px;
            height: 100px;
            display: inline-block;
            text-align: center;
            line-height: 100px;
            font-weight: bold;
            color: #2c3e50;
            margin: 20px auto;
        }
        .generated-date {
            font-size: 14px;
            color: #7f8c8d;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">OpenLaw Kenya</div>
        <div>Land Due Diligence & Litigation Intelligence System</div>
    </div>

    <div class="certificate-type">
        
            CLEARANCE CERTIFICATE
        
    </div>

    <div class="certificate-id">
        Certificate ID: c0d467ca-4001-409a-8100-a950dd34830d
    </div>

    <div class="section">
        <div class="section-title">Land Details</div>
        <div class="land-details">
            <strong>Title Number:</strong> TEST/123/456<br>
            <strong>LR Number:</strong> TEST/123/456<br>
            <strong>Plot Number:</strong> TEST/123/456<br>
            
            
            
        </div>
    </div>

    
    <div class="section">
        <div class="section-title">Clearance Status</div>
        <div style="background-color: #d4edda; padding: 15px; border-left: 4px solid #28a745;">
            <strong>✓ No litigation cases found</strong><br>
            This land parcel has a clean record with no registered court cases in our system.
        </div>
    </div>
    

    <div class="footer">
        <div class="stamp">OFFICIAL</div>
        <div>This certificate is electronically generated by OpenLaw Kenya</div>
        <div class="generated-date">Generated on: 25 February 2026</div>
    </div>
</body>
</html>
