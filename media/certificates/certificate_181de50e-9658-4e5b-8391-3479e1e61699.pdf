<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>OpenLaw Certificate</title>
    <style>
        @page {
            size: A4;
            margin: 2cm;
        }
        body {
            font-family: 'Times New Roman', serif;
            line-height: 1.6;
            color: #333;
        }
        .header {
            text-align: center;
            border-bottom: 3px solid #2c3e50;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        .logo {
            font-size: 28px;
            font-weight: bold;
            color: #2c3e50;
            margin-bottom: 10px;
        }
        .certificate-type {
            font-size: 24px;
            font-weight: bold;
            color: #34495e;
            margin: 20px 0;
            text-align: center;
        }
        .certificate-id {
            text-align: center;
            font-size: 14px;
            color: #7f8c8d;
            margin-bottom: 30px;
        }
        .section {
            margin: 20px 0;
        }
        .section-title {
            font-weight: bold;
            font-size: 16px;
            color: #2c3e50;
            margin-bottom: 10px;
        }
        .land-details {
            background-color: #f8f9fa;
            padding: 15px;
            border-left: 4px solid #3498db;
            margin: 20px 0;
        }
        .case-item {
            background-color: #fff9e6;
            padding: 10px;
            margin: 10px 0;
            border-left: 4px solid #f39c12;
        }
        .footer {
            margin-top: 50px;
            text-align: center;
            border-top: 2px solid #2c3e50;
            padding-top: 20px;
        }
        .stamp {
            border: 2px solid #2c3e50;
            border-radius: 50%;
            width: 100px;
            height: 100px;
            display: inline-block;
            text-align: center;
            line-height: 100px;
            font-weight: bold;
            color: #2c3e50;
            margin: 20px auto;
        }
        .generated-date {
            font-size: 14px;
            color: #7f8c8d;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">OpenLaw Kenya</div>
        <div>Land Due Diligence & Litigation Intelligence System</div>
    </div>

    <div class="certificate-type">
        
            CASE-LINKED CERTIFICATE
        
    </div>

    <div class="certificate-id">
        Certificate ID: 181de50e-9658-4e5b-8391-3479e1e61699
    </div>

    <div class="section">
        <div class="section-title">Land Details</div>
        <div class="land-details">
            <strong>Title Number:</strong> 778/1<br>
            
            <strong>Plot Number:</strong> 778/1<br>
            
            
            
        </div>
    </div>

    
    <div class="section">
        <div class="section-title">Related Cases (1 found)</div>
        
        <div class="case-item">
            <strong>Case Number:</strong> KEELC/2019/13<br>
            <strong>Case Name:</strong> Rural Housing Estate v National Land Commission &amp; 2 others [2019] KEELC 13 (KLR)<br>
            <strong>Court:</strong> KISUMU<br>
            <strong>Year:</strong> 2019<br>
            <strong>Status:</strong> Judgment<br>
            <strong>Parties:</strong> Plaintiff: Rural Housing Estate
Defendant: National Land Commission &amp; 2 others
        </div>
        
    </div>
    

    <div class="footer">
        <div class="stamp">OFFICIAL</div>
        <div>This certificate is electronically generated by OpenLaw Kenya</div>
        <div class="generated-date">Generated on: 25 February 2026</div>
    </div>
</body>
</html>
